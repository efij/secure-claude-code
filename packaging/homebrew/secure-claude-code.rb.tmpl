class SecureClaudeCode < Formula
  desc "Local-first hardening toolkit for Claude Code"
  homepage "https://github.com/{{REPO}}"
  url "https://github.com/{{REPO}}/releases/download/v{{VERSION}}/secure-claude-code-{{VERSION}}.tar.gz"
  sha256 "{{SHA256_TGZ}}"
  license "MIT"

  def install
    libexec.install Dir["*"]
    (bin/"secure-claude-code").write <<~EOS
      #!/bin/bash
      exec "#{libexec}/bin/secure-claude-code" "$@"
    EOS
  end

  test do
    assert_match "Usage:", shell_output("#{bin}/secure-claude-code --help")
  end
end
