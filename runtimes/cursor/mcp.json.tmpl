{
  "mcpServers": {
    "runwall": {
      "type": "stdio",
      "command": "{{PYTHON_BIN}}",
      "args": [
        "{{ROOT_DIR}}/scripts/runwall_gateway.py",
        "--root",
        "{{ROOT_DIR}}",
        "--profile",
        "{{PROFILE}}",
        "--config",
        "{{ROOT_DIR}}/config/gateway.json",
        "--api-port",
        "9470"
      ]
    }
  }
}
