# GitHub Actions snippet for Runwall CI mode
- name: Runwall policy validation
  run: |
    python3 scripts/validate-patterns.py config
    ./bin/runwall validate

# Example policy gate for high-risk generated commands:
- name: Runwall gate deploy command
  env:
    RUNWALL_COMMAND: "kubectl --context prod apply -f deploy.yaml"
  run: |
    ./bin/runwall evaluate PreToolUse Bash "$RUNWALL_COMMAND" --profile strict --json
