"(permissions|tools|allow|scopes)"[[:space:]]*:[[:space:]]*\[[^]]*"\*"
"(allowAllTools|allow_all|dangerouslySkipPermissions|dangerously_allow_all)"[[:space:]]*:[[:space:]]*true
"(network|shell|bash|exec|execute|subprocess|command)"[[:space:]]*:[[:space:]]*true
"(fileWrite|write|filesystem-write|filesystem_write|secrets|credential|credentials|env)"[[:space:]]*:[[:space:]]*true
