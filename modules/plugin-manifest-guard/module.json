{
  "id": "plugin-manifest-guard",
  "name": "Plugin Manifest Guard Pack",
  "description": "Blocks risky plugin and extension sources being added through manifest files.",
  "category": "plugin",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "change-safety.md",
    "security-baseline.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Write|Edit|MultiEdit|Bash",
    "type": "command",
    "command": "bash ~/.secure-claude-code/hooks/plugin-manifest-guard.sh \"$TOOL_INPUT\""
  }
}
