{
  "id": "public-artifact-secret-guard",
  "name": "Public Artifact Secret Guard Pack",
  "description": "Blocks copying secrets and key material into public, build, release, or artifact directories.",
  "category": "secrets",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "security-baseline.md",
    "change-safety.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "type": "command",
    "command": "bash ~/.runwall/hooks/public-artifact-secret-guard.sh \"$TOOL_INPUT\""
  }
}
