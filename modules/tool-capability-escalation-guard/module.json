{
  "id": "tool-capability-escalation-guard",
  "name": "Tool Capability Escalation Guard Pack",
  "description": "Blocks MCP tool definitions that combine broad shell, file, and network reach in one widened capability surface.",
  "category": "mcp",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "security-baseline.md",
    "tool-safety.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "mcp__.*",
    "type": "command",
    "command": "bash ~/.runwall/hooks/tool-capability-escalation-guard.sh \"$TOOL_INPUT\""
  }
}
