{
  "id": "desktop-credential-store-guard",
  "name": "Desktop Credential Store Guard Pack",
  "description": "Blocks direct access to OS-backed credential stores such as Keychain, libsecret, and Windows Credential Manager.",
  "category": "secrets",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "change-safety.md",
    "security-baseline.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "type": "command",
    "command": "bash ~/.runwall/hooks/desktop-credential-store-guard.sh \"$TOOL_INPUT\""
  }
}
