{
  "id": "instruction-override-bridge-guard",
  "name": "Instruction Override Bridge Guard Pack",
  "description": "Blocks trusted instruction files that tell the runtime to bypass Runwall or trust tool output over local policy.",
  "category": "prompt-injection",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "security-baseline.md",
    "tool-safety.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Write|Edit|MultiEdit|Bash",
    "type": "command",
    "command": "bash ~/.runwall/hooks/instruction-override-bridge-guard.sh \"$TOOL_INPUT\""
  }
}
