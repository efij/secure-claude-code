{
  "id": "kube-secret-guard",
  "name": "Kubernetes Secret Guard Pack",
  "description": "Blocks direct reads and edits of live Kubernetes secrets through kubectl command flows.",
  "category": "secrets",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "security-baseline.md",
    "change-safety.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "type": "command",
    "command": "bash ~/.secure-claude-code/hooks/kube-secret-guard.sh \"$TOOL_INPUT\""
  }
}
