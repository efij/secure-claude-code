{
  "id": "post-edit-quality-reminder",
  "name": "Quality Reminder Pack",
  "description": "Suggests formatting, linting, and test commands based on the files the agent just touched.",
  "category": "quality",
  "kind": "assist",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "workflow.md",
    "context-discipline.md"
  ],
  "hook": {
    "event": "PostToolUse",
    "matcher": "Write|Edit|MultiEdit",
    "type": "command",
    "command": "bash ~/.runwall/hooks/post-edit-quality-reminder.sh \"$TOOL_INPUT\"",
    "async": true
  }
}
