{
  "id": "prod-db-dump-guard",
  "name": "Production Database Dump Guard Pack",
  "description": "Blocks dump and export commands aimed at production-like databases and customer data stores.",
  "category": "infra",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "change-safety.md",
    "security-baseline.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "type": "command",
    "command": "bash ~/.runwall/hooks/prod-db-dump-guard.sh \"$TOOL_INPUT\""
  }
}
