{
  "id": "sideloaded-extension-guard",
  "name": "Sideloaded Extension Guard Pack",
  "description": "Blocks sideloaded local plugin and extension installs from temp, download, archive, or unpacked paths outside reviewed sources.",
  "category": "plugin",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "change-safety.md",
    "security-baseline.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Write|Edit|MultiEdit|Bash",
    "type": "command",
    "command": "bash ~/.secure-claude-code/hooks/sideloaded-extension-guard.sh \"$TOOL_INPUT\""
  }
}
