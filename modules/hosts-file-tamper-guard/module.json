{
  "id": "hosts-file-tamper-guard",
  "name": "Hosts File Tamper Guard Pack",
  "description": "Blocks local hosts-file remaps for high-trust infrastructure domains.",
  "category": "trust-boundary",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "change-safety.md",
    "security-baseline.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Write|Edit|MultiEdit|Bash",
    "type": "command",
    "command": "bash ~/.runwall/hooks/hosts-file-tamper-guard.sh \"$TOOL_INPUT\""
  }
}
