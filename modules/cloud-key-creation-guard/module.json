{
  "id": "cloud-key-creation-guard",
  "name": "Cloud Key Creation Guard Pack",
  "description": "Blocks agent-driven creation of long-lived cloud access keys and service-account credentials.",
  "category": "cloud",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "change-safety.md",
    "security-baseline.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "type": "command",
    "command": "bash ~/.runwall/hooks/cloud-key-creation-guard.sh \"$TOOL_INPUT\""
  }
}
