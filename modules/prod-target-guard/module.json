{
  "id": "prod-target-guard",
  "name": "Production Target Guard Pack",
  "description": "Blocks direct mutating commands against production-like deploy and infrastructure targets.",
  "category": "deploy",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "workflow.md",
    "change-safety.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "type": "command",
    "command": "bash ~/.runwall/hooks/prod-target-guard.sh \"$TOOL_INPUT\""
  }
}
