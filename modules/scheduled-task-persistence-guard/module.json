{
  "id": "scheduled-task-persistence-guard",
  "name": "Scheduled Task Persistence Guard Pack",
  "description": "Blocks recurring OS task, service, and launch-item registration that can be used for persistence.",
  "category": "persistence",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "change-safety.md",
    "security-baseline.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Write|Edit|MultiEdit|Bash",
    "type": "command",
    "command": "bash ~/.runwall/hooks/scheduled-task-persistence-guard.sh \"$TOOL_INPUT\""
  }
}
