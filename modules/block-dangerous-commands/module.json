{
  "id": "block-dangerous-commands",
  "name": "Dangerous Shell Signature Pack",
  "description": "Stops remote shell piping, destructive permission changes, and a few high-confidence destructive commands.",
  "category": "shell",
  "kind": "block",
  "default_profiles": ["strict"],
  "rules": [
    "security-baseline.md",
    "change-safety.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "type": "command",
    "command": "bash ~/.secure-claude-code/hooks/block-dangerous-commands.sh \"$TOOL_INPUT\""
  }
}
