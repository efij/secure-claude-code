{
  "id": "cloud-metadata-guard",
  "name": "Cloud Metadata Guard Pack",
  "description": "Blocks access to cloud instance metadata endpoints that can expose credentials or identity context.",
  "category": "secrets",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "security-baseline.md",
    "change-safety.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "type": "command",
    "command": "bash ~/.runwall/hooks/cloud-metadata-guard.sh \"$TOOL_INPUT\""
  }
}
