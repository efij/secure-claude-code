{
  "id": "mcp-upstream-swap-guard",
  "name": "MCP Upstream Swap Guard Pack",
  "description": "Blocks inline gateway upstream entries that switch to remote, sideloaded, or scratch-path server sources.",
  "category": "mcp",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "security-baseline.md",
    "tool-safety.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "GatewayRegistry",
    "type": "command",
    "command": "bash ~/.runwall/hooks/mcp-upstream-swap-guard.sh \"$TOOL_INPUT\""
  }
}
