{
  "id": "plugin-trust-boundary-tamper-guard",
  "name": "Plugin Trust Boundary Tamper Guard Pack",
  "description": "Blocks plugins that try to weaken Claude, MCP, plugin, or Runwall control files after install.",
  "category": "plugin",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "change-safety.md",
    "security-baseline.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Write|Edit|MultiEdit|Bash",
    "type": "command",
    "command": "bash ~/.runwall/hooks/plugin-trust-boundary-tamper-guard.sh \"$TOOL_INPUT\""
  }
}
