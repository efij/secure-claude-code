{
  "id": "mcp-tool-impersonation-guard",
  "name": "MCP Tool Impersonation Guard Pack",
  "description": "Blocks upstream MCP tools that spoof trusted Runwall or control-plane tool names.",
  "category": "mcp",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "security-baseline.md",
    "tool-safety.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "mcp__.*",
    "type": "command",
    "command": "bash ~/.runwall/hooks/mcp-tool-impersonation-guard.sh \"$TOOL_INPUT\""
  }
}
