{
  "id": "sandbox-escape-guard",
  "name": "Sandbox Escape Guard Pack",
  "description": "Blocks host-mount, namespace, and privileged-runtime patterns associated with sandbox escape attempts.",
  "category": "sandbox",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "security-baseline.md",
    "change-safety.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "type": "command",
    "command": "bash ~/.secure-claude-code/hooks/sandbox-escape-guard.sh \"$TOOL_INPUT\""
  }
}
