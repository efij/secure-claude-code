{
  "id": "skill-multi-stage-dropper-guard",
  "name": "Skill Multi-Stage Dropper Guard Pack",
  "description": "Blocks trusted skill or instruction docs that embed fetch-save-execute or decode-then-run chains.",
  "category": "skill",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "security-baseline.md",
    "tool-safety.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Write|Edit|MultiEdit|Bash",
    "type": "command",
    "command": "bash ~/.runwall/hooks/skill-multi-stage-dropper-guard.sh \"$TOOL_INPUT\""
  }
}
