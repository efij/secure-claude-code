{
  "id": "local-ca-trust-guard",
  "name": "Local CA Trust Guard Pack",
  "description": "Prompts when the runtime tries to add new root or trust-anchor certificates to the machine.",
  "category": "trust",
  "kind": "prompt",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "security-baseline.md",
    "context-discipline.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "type": "command",
    "command": "bash ~/.runwall/hooks/local-ca-trust-guard.sh \"$TOOL_INPUT\""
  }
}
