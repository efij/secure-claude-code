{
  "id": "mcp-tool-schema-widening-guard",
  "name": "MCP Tool Schema Widening Guard Pack",
  "description": "Blocks sensitive MCP tools that suddenly widen into free-form schemas.",
  "category": "mcp",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "security-baseline.md",
    "tool-safety.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "mcp__.*",
    "type": "command",
    "command": "bash ~/.runwall/hooks/mcp-tool-schema-widening-guard.sh \"$TOOL_INPUT\""
  }
}
