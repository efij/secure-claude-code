{
  "id": "browser-remote-debug-guard",
  "name": "Browser Remote Debug Guard Pack",
  "description": "Blocks browser remote-debugging launches that expose live sessions and cookies to the runtime.",
  "category": "session",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "security-baseline.md",
    "context-discipline.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "type": "command",
    "command": "bash ~/.runwall/hooks/browser-remote-debug-guard.sh \"$TOOL_INPUT\""
  }
}
