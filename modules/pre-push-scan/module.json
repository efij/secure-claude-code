{
  "id": "pre-push-scan",
  "name": "Secret and Exfiltration Scan Pack",
  "description": "Scans source files for likely secrets, internal network data, and connection strings before push.",
  "category": "secrets",
  "kind": "block",
  "default_profiles": ["minimal", "balanced", "strict"],
  "rules": [
    "security-baseline.md",
    "review-checklist.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "type": "command",
    "command": "bash ~/.runwall/hooks/pre-push-scan.sh \"$TOOL_INPUT\""
  }
}
