{
  "id": "remote-script-dropper-guard",
  "name": "Remote Script Dropper Guard Pack",
  "description": "Blocks remote content being dropped into script or executable paths in preparation for local execution.",
  "category": "shell",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "security-baseline.md",
    "change-safety.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "type": "command",
    "command": "bash ~/.secure-claude-code/hooks/remote-script-dropper-guard.sh \"$TOOL_INPUT\""
  }
}
