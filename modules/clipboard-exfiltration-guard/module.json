{
  "id": "clipboard-exfiltration-guard",
  "name": "Clipboard Exfiltration Guard Pack",
  "description": "Blocks copying likely secrets and tokens into clipboard tools.",
  "category": "secrets",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "security-baseline.md",
    "change-safety.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "type": "command",
    "command": "bash ~/.secure-claude-code/hooks/clipboard-exfiltration-guard.sh \"$TOOL_INPUT\""
  }
}
