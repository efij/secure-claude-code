{
  "id": "ci-self-hosted-runner-guard",
  "name": "CI Self-Hosted Runner Guard Pack",
  "description": "Blocks high-risk workflow patterns that combine self-hosted runners with untrusted PR triggers.",
  "category": "supply-chain",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "security-baseline.md",
    "change-safety.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "type": "command",
    "command": "bash ~/.runwall/hooks/ci-self-hosted-runner-guard.sh \"$TOOL_INPUT\""
  }
}
