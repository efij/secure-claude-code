{
  "id": "browser-profile-export-guard",
  "name": "Browser Profile Export Guard Pack",
  "description": "Blocks copying or archiving full browser profiles that can contain sessions and saved credentials.",
  "category": "secrets",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "change-safety.md",
    "security-baseline.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "type": "command",
    "command": "bash ~/.secure-claude-code/hooks/browser-profile-export-guard.sh \"$TOOL_INPUT\""
  }
}
