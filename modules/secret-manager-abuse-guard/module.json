{
  "id": "secret-manager-abuse-guard",
  "name": "Secret Manager Abuse Guard Pack",
  "description": "Prompts when agents pull live secrets directly from Vault, cloud secret managers, or desktop password tooling.",
  "category": "secrets",
  "kind": "prompt",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "security-baseline.md",
    "review-checklist.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "type": "command",
    "command": "bash ~/.runwall/hooks/secret-manager-abuse-guard.sh \"$TOOL_INPUT\""
  }
}
