{
  "id": "signed-commit-bypass-guard",
  "name": "Signed Commit Bypass Guard Pack",
  "description": "Blocks changes that disable commit or tag signing and weaken provenance checks.",
  "category": "integrity",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "change-safety.md",
    "security-baseline.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "type": "command",
    "command": "bash ~/.runwall/hooks/signed-commit-bypass-guard.sh \"$TOOL_INPUT\""
  }
}
