{
  "id": "package-manager-auth-inline-guard",
  "name": "Package Manager Auth Inline Guard Pack",
  "description": "Blocks live tokens and credentials pasted into package-manager auth files and config.",
  "category": "secrets",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "security-baseline.md",
    "change-safety.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "type": "command",
    "command": "bash ~/.runwall/hooks/package-manager-auth-inline-guard.sh \"$TOOL_INPUT\""
  }
}
