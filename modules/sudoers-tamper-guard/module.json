{
  "id": "sudoers-tamper-guard",
  "name": "Sudoers Tamper Guard Pack",
  "description": "Blocks edits that weaken sudo policy or password requirements.",
  "category": "privilege",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "change-safety.md",
    "security-baseline.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Write|Edit|MultiEdit|Bash",
    "type": "command",
    "command": "bash ~/.runwall/hooks/sudoers-tamper-guard.sh \"$TOOL_INPUT\""
  }
}
