{
  "id": "netrc-credential-guard",
  "name": "Netrc Credential Guard Pack",
  "description": "Blocks direct reads and exports of .netrc credential files.",
  "category": "secrets",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "change-safety.md",
    "security-baseline.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Read|Bash",
    "type": "command",
    "command": "bash ~/.runwall/hooks/netrc-credential-guard.sh \"$TOOL_INPUT\""
  }
}
