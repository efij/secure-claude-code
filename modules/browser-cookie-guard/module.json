{
  "id": "browser-cookie-guard",
  "name": "Browser Cookie Guard Pack",
  "description": "Blocks reads and exports of browser cookie, login, and session stores.",
  "category": "secrets",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "security-baseline.md",
    "change-safety.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "type": "command",
    "command": "bash ~/.runwall/hooks/browser-cookie-guard.sh \"$TOOL_INPUT\""
  }
}
