{
  "id": "ssh-authorized-keys-guard",
  "name": "SSH Authorized Keys Guard Pack",
  "description": "Blocks agent-driven writes to authorized_keys and related SSH login trust material.",
  "category": "persistence",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "change-safety.md",
    "security-baseline.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Write|Edit|MultiEdit|Bash",
    "type": "command",
    "command": "bash ~/.runwall/hooks/ssh-authorized-keys-guard.sh \"$TOOL_INPUT\""
  }
}
