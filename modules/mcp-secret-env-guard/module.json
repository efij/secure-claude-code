{
  "id": "mcp-secret-env-guard",
  "name": "MCP Secret Env Guard Pack",
  "description": "Warns when high-value secret environment variables are forwarded into MCP server definitions.",
  "category": "mcp",
  "kind": "warn",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "security-baseline.md",
    "tool-safety.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Write|Edit|MultiEdit|Bash",
    "type": "command",
    "command": "bash ~/.secure-claude-code/hooks/mcp-secret-env-guard.sh \"$TOOL_INPUT\""
  }
}
