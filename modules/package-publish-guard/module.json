{
  "id": "package-publish-guard",
  "name": "Package Publish Guard Pack",
  "description": "Warns when the agent is about to publish packages, releases, or pushed artifacts outside the repo boundary.",
  "category": "release",
  "kind": "warn",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "workflow.md",
    "review-checklist.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "type": "command",
    "command": "bash ~/.secure-claude-code/hooks/package-publish-guard.sh \"$TOOL_INPUT\""
  }
}
