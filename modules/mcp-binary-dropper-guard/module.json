{
  "id": "mcp-binary-dropper-guard",
  "name": "MCP Binary Dropper Guard Pack",
  "description": "Redacts upstream MCP responses that look like executable, archive, or second-stage payload material.",
  "category": "mcp",
  "kind": "redact",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "security-baseline.md",
    "tool-safety.md"
  ],
  "hook": {
    "event": "PostToolUse",
    "matcher": "mcp__.*",
    "type": "command",
    "command": "bash ~/.runwall/hooks/mcp-binary-dropper-guard.sh \"$TOOL_INPUT\""
  }
}
