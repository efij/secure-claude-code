{
  "id": "registry-target-guard",
  "name": "Registry Target Guard Pack",
  "description": "Blocks publish and login flows that target unexpected package or container registries.",
  "category": "supply-chain",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "change-safety.md",
    "security-baseline.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "type": "command",
    "command": "bash ~/.runwall/hooks/registry-target-guard.sh \"$TOOL_INPUT\""
  }
}
