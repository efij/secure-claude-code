{
  "id": "mcp-install-source-allowlist",
  "name": "MCP Install Source Allowlist Pack",
  "description": "Blocks MCP and plugin install sources outside a reviewed allowlist.",
  "category": "mcp",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "change-safety.md",
    "security-baseline.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "type": "command",
    "command": "bash ~/.runwall/hooks/mcp-install-source-allowlist.sh \"$TOOL_INPUT\""
  }
}
