{
  "id": "oauth-device-flow-guard",
  "name": "OAuth Device Flow Guard Pack",
  "description": "Prompts when agent-driven device-code and browserless OAuth login flows try to mint delegated user access.",
  "category": "identity",
  "kind": "prompt",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "security-baseline.md",
    "context-discipline.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "type": "command",
    "command": "bash ~/.runwall/hooks/oauth-device-flow-guard.sh \"$TOOL_INPUT\""
  }
}
