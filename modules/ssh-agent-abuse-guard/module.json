{
  "id": "ssh-agent-abuse-guard",
  "name": "SSH Agent Abuse Guard Pack",
  "description": "Blocks agent forwarding and SSH agent extraction patterns that widen key trust boundaries.",
  "category": "secrets",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "security-baseline.md",
    "change-safety.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "type": "command",
    "command": "bash ~/.runwall/hooks/ssh-agent-abuse-guard.sh \"$TOOL_INPUT\""
  }
}
