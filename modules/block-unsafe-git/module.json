{
  "id": "block-unsafe-git",
  "name": "Git Safety Signature Pack",
  "description": "Blocks hook bypasses, force pushes to protected branches, and hard resets on protected branches.",
  "category": "git",
  "kind": "block",
  "default_profiles": ["minimal", "balanced", "strict"],
  "rules": [
    "security-baseline.md",
    "workflow.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "type": "command",
    "command": "bash ~/.runwall/hooks/block-unsafe-git.sh \"$TOOL_INPUT\""
  }
}
