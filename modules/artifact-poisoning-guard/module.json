{
  "id": "artifact-poisoning-guard",
  "name": "Artifact Poisoning Guard Pack",
  "description": "Blocks direct tampering with release artifacts, checksums, and signature material outside the normal packaging path.",
  "category": "supply-chain",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "change-safety.md",
    "security-baseline.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "type": "command",
    "command": "bash ~/.secure-claude-code/hooks/artifact-poisoning-guard.sh \"$TOOL_INPUT\""
  }
}
