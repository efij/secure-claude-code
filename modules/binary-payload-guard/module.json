{
  "id": "binary-payload-guard",
  "name": "Binary Payload Guard Pack",
  "description": "Blocks downloaded or decoded executable payloads from being staged for local execution.",
  "category": "shell",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "security-baseline.md",
    "change-safety.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "type": "command",
    "command": "bash ~/.runwall/hooks/binary-payload-guard.sh \"$TOOL_INPUT\""
  }
}
