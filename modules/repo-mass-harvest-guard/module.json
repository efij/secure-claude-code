{
  "id": "repo-mass-harvest-guard",
  "name": "Repo Mass Harvest Guard Pack",
  "description": "Blocks bulk repo packing and enumeration patterns that look ready for export or staging.",
  "category": "network",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "security-baseline.md",
    "context-discipline.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "type": "command",
    "command": "bash ~/.secure-claude-code/hooks/repo-mass-harvest-guard.sh \"$TOOL_INPUT\""
  }
}
