{
  "id": "config-tamper-guard",
  "name": "Config Tamper Guard Pack",
  "description": "Blocks edits that weaken Claude, MCP, or CI control files with bypass or wildcard-permission patterns.",
  "category": "config",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "security-baseline.md",
    "review-checklist.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Write|Edit|MultiEdit|Bash",
    "type": "command",
    "command": "bash ~/.runwall/hooks/config-tamper-guard.sh \"$TOOL_INPUT\""
  }
}
