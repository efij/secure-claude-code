{
  "id": "trusted-config-symlink-guard",
  "name": "Trusted Config Symlink Guard Pack",
  "description": "Blocks symlink redirection of trusted config, policy, and instruction files.",
  "category": "trust-boundary",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "change-safety.md",
    "security-baseline.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "type": "command",
    "command": "bash ~/.runwall/hooks/trusted-config-symlink-guard.sh \"$TOOL_INPUT\""
  }
}
