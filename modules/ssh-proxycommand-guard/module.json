{
  "id": "ssh-proxycommand-guard",
  "name": "SSH ProxyCommand Guard Pack",
  "description": "Blocks ProxyCommand, LocalCommand, and related SSH config hooks that create covert execution paths.",
  "category": "trust",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "security-baseline.md",
    "change-safety.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Bash",
    "type": "command",
    "command": "bash ~/.runwall/hooks/ssh-proxycommand-guard.sh \"$TOOL_INPUT\""
  }
}
