{
  "id": "workspace-boundary-guard",
  "name": "Workspace Boundary Guard Pack",
  "description": "Blocks system-path and deep-parent traversal patterns that leave normal workspace boundaries.",
  "category": "files",
  "kind": "block",
  "default_profiles": ["balanced", "strict"],
  "rules": [
    "security-baseline.md",
    "context-discipline.md"
  ],
  "hook": {
    "event": "PreToolUse",
    "matcher": "Read|Write|Edit|MultiEdit|Bash",
    "type": "command",
    "command": "bash ~/.secure-claude-code/hooks/workspace-boundary-guard.sh \"$TOOL_INPUT\""
  }
}
